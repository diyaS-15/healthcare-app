# ============================================================================
# Blood Report AI - Frontend Environment Variables
# Copy this to .env.local and fill in your own values
# ============================================================================

# ━━━━━━━━━━ SUPABASE ━━━━━━━━━━
# Get from: https://supabase.com/dashboard → Project Settings → API
# These are public values (anon key is safe to expose in browser)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ━━━━━━━━━━ BACKEND API ━━━━━━━━━━
# Point to your FastAPI backend server
# Development: http://localhost:8000
# Production: https://yourdomain.com/api (or your Railway URL)
VITE_API_URL="http://localhost:8000/api"

# ============================================================================
# DEVELOPMENT:
# npm run dev
# Make sure backend is running on http://localhost:8000

# PRODUCTION:
# Update VITE_API_URL to your deployed backend URL
# Build with: npm run build
# Deploy to Vercel or similar
# ============================================================================
