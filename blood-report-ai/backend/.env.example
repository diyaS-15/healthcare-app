# ============================================================================
# Blood Report AI - Backend Environment Variables
# Copy this to .env and fill in your own values
# ============================================================================

# ━━━━━━━━━━ SUPABASE ━━━━━━━━━━
# Get these from: https://supabase.com/dashboard
# Create a new project, then go to Project Settings → API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_JWT_SECRET="your_jwt_secret_from_supabase"

# ━━━━━━━━━━ OPENAI API ━━━━━━━━━━
# Get from: https://platform.openai.com/api-keys
# We use GPT-4o for intelligent report parsing and explanations
OPENAI_API_KEY="sk-..."

# ━━━━━━━━━━ ELEVENLABS (Speech) ━━━━━━━━━━
# Get from: https://elevenlabs.io/api
# Optional - for voice chat features
ELEVENLABS_API_KEY="optional_api_key"
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ━━━━━━━━━━ ENCRYPTION ━━━━━━━━━━
# Generate a 64-character hex string for AES-256 encryption
# Command: openssl rand -hex 32
ENCRYPTION_SECRET="f47ac10b2540c4d46da6ff3e5f3b3f0d5e7a3c1b9f2e4d6a8c0b1e3f5a7d9b1"

# ━━━━━━━━━━ JWT & AUTH ━━━━━━━━━━
JWT_SECRET="your_super_secret_jwt_key_for_token_signing"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440  # 24 hours

# ━━━━━━━━━━ APP SETTINGS ━━━━━━━━━━
APP_ENV="development"  # or "production"
APP_NAME="Blood Report AI"
APP_VERSION="2.0.0"

# CORS Origins (comma-separated)
# Include your frontend URL + localhost for development
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,https://yourdomain.com"

# File upload limits
MAX_UPLOAD_SIZE_MB=20

# ━━━━━━━━━━ LOGGING ━━━━━━━━━━
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR

# ============================================================================
# PRODUCTION DEPLOYMENT:
# 1. Use strong, randomly generated encryption and JWT secrets
# 2. Set APP_ENV="production"
# 3. Only include your actual frontend URLs in ALLOWED_ORIGINS
# 4. Store secrets in Railway/Vercel environment variables (never in .env)
# ============================================================================
